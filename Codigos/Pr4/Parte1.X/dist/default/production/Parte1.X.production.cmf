temp COMRAM 1 20 20 1 1 1
intcode CODE 0 8 8 6 1 2
smallconst SMALLCONST 0 800 800 E 1 2
bssCOMRAM COMRAM 1 17 17 9 1 1
config CONFIG 4 300000 300000 E 1 1
$C:\Users\UsuarioF\AppData\Local\Temp\xcAsm3g.\driver_tmp_9.o
idloc IDLOC 5 200000 200000 8 1 1
init CODE 0 E E 4 1 2
